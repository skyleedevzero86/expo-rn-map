{
  "name": "location-tracking-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --port 9080",
    "start:tunnel": "expo start --tunnel --port 9080",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "firewall:allow": "node scripts/run-allow-firewall.js",
    "tunnel:api": "npx ngrok http 8080",
    "android": "expo start --android --port 9080",
    "start:android": "adb reverse tcp:9080 tcp:9080 & expo start --android --port 9080",
    "adb-reverse": "adb reverse tcp:9080 tcp:9080",
    "ios": "expo start --ios --port 9080",
    "web": "expo start --web --port 9080",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "expo": "~54.0.33",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.17",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@9.14.2"
}
